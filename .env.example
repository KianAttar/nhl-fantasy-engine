# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite for local development
DATABASE_URL=sqlite:///db.sqlite3
# Postgres for production (docker-compose sets this automatically)
# DATABASE_URL=postgres://nhl:nhl@localhost:5432/nhl_fantasy

# ── Cache ─────────────────────────────────────────────────────────────────────
# In-process memory cache for local development
CACHE_URL=locmemcache://
# Redis for production (docker-compose sets this automatically)
# CACHE_URL=redis://localhost:6379/1

# ── Redis / Celery broker ─────────────────────────────────────────────────────
# Only required when running Celery worker or beat
REDIS_URL=redis://localhost:6379/0

# ── Sentry ────────────────────────────────────────────────────────────────────
# Leave empty to disable error tracking
SENTRY_DSN=
